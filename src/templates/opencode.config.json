{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["{file:./prompts/hierarchy.txt}"],
  "permission": {
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "secrets/**": "deny"
    }
  },
  "agent": {
    "plan": { "hidden": true },
    "build": { "hidden": true },

    "planner": {
      "mode": "primary",
      "description": "Turns a user request into a verified PRD via examiner/plan-writer/plan-checker, then decides build-or-revise. Cannot write or edit code.",
      "prompt": "{file:./prompts/planner.txt}",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "task": {
          "*": "deny",
          "examiner": "allow",
          "plan-writer": "allow",
          "plan-checker": "allow"
        }
      }
    },

    "builder": {
      "mode": "primary",
      "description": "Executes a confirmed PRD by orchestrating Coder/Tester/Verifier/Writer. Cannot edit files, run bash, or change requirements directly.",
      "prompt": "{file:./prompts/builder.txt}",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "coder": "allow",
          "tester": "allow",
          "verifier": "allow",
          "writer": "allow"
        }
      }
    },

    "reviewer": {
      "mode": "primary",
      "temperature": 0.1,
      "description": "Reviews completed work for traceability and regression risk via tracer/debugger/inspector/reporter. Cannot edit or write code.",
      "prompt": "{file:./prompts/reviewer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "rg *": "allow"
        },
        "task": {
          "*": "deny",
          "tracer": "allow",
          "debugger": "allow",
          "inspector": "allow",
          "reporter": "allow"
        }
      }
    },

    "coder": {
      "mode": "subagent",
      "description": "Implements tasks assigned by Builder, following the PRD exactly. Tracks own progress via todowrite.",
      "prompt": "{file:./prompts/coder.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "todowrite": "allow",
        "bash": "allow",
        "task": "deny"
      }
    },

    "debugger": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Diagnoses defects via reproduce -> isolate -> source -> remedy, called by Reviewer. Cannot fix code directly.",
      "prompt": "{file:./prompts/debugger.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow"
        },
        "task": "deny"
      }
    },

    "tester": {
      "mode": "subagent",
      "description": "Runs tests on implemented code and reports results (PASS/FAIL/BLOCKED) with coverage gaps. Cannot fix code, redesign tests, or decide next steps.",
      "prompt": "{file:./prompts/tester.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "todowrite": "deny",
        "bash": "allow",
        "task": "deny"
      }
    },

    "examiner": {
      "mode": "subagent",
      "description": "Researches technical and codebase context for Planner during PRD preparation. Outputs confirmed_facts / inferred_facts / unknowns / risks only.",
      "prompt": "{file:./prompts/examiner.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "deny"
      }
    },

    "plan-writer": {
      "mode": "subagent",
      "description": "Stateless formatter for Planner. Produces PRD documents from structured input — no inference, no decisions. PRD mode only.",
      "prompt": "{file:./prompts/plan-writer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "edit": {
          "*": "deny",
          "docs/plans/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/plans/**": "allow"
        },
        "bash": "deny",
        "task": "deny"
      }
    },

    "plan-checker": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Boolean gate for Planner: checks PRD completeness against original user request. PASS/FAIL + gap list only.",
      "prompt": "{file:./prompts/plan-checker.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny"
      }
    },

    "tracer": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Boolean gate for Reviewer: traces PRD requirements to implemented code. PASS/FAIL + traceability table only.",
      "prompt": "{file:./prompts/tracer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny"
      }
    },

    "inspector": {
      "mode": "subagent",
      "description": "Researches technical and codebase context for Reviewer during review/RCA. Outputs confirmed_facts / inferred_facts / unknowns / risks only.",
      "prompt": "{file:./prompts/inspector.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "deny"
      }
    },

    "reporter": {
      "mode": "subagent",
      "description": "Stateless formatter for Reviewer. Produces review/debug reports from structured input — no inference, no decisions. Summary mode only.",
      "prompt": "{file:./prompts/reporter.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "edit": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "bash": "deny",
        "task": "deny"
      }
    },

    "verifier": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Boolean gate for Builder: compares implementation against PRD definition-of-done. PASS/FAIL + gap list only.",
      "prompt": "{file:./prompts/verifier.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny"
      }
    },

    "writer": {
      "mode": "subagent",
      "description": "Stateless formatter for Builder. Produces Summary/Report documents from structured input — no inference, no decisions. Summary mode only.",
      "prompt": "{file:./prompts/writer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "edit": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "bash": "deny",
        "task": "deny"
      }
    }
  }
}
