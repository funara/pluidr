{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["{file:./prompts/hierarchy.txt}"],
  "permission": {
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "secrets/**": "deny"
    }
  },
  "agent": {
    "plan": { "hidden": true },
    "build": { "hidden": true },

    "composer": {
      "mode": "primary",
      "temperature": 0.7,
      "description": "Full engineering workflow: Explore, Plan, Build — 3 phases, 7 subagents. Starts in Explore mode, transitions via guardrail gates.",
      "prompt": "{file:./prompts/composer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "bash": {
          "*": "deny",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": {
          "*": "deny",
          "researcher": "allow",
          "plan-writer": "allow",
          "plan-checker": "allow",
          "coder": "allow",
          "tester": "allow",
          "reviewer": "allow",
          "writer": "allow"
        }
      }
    },

    "debugger": {
      "mode": "primary",
      "description": "Root-cause analysis via inspector/fixer/reporter. Standalone primary agent — does not depend on Builder. Cannot edit files or run bash directly.",
      "prompt": "{file:./prompts/debugger.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "question": "allow",
        "task": {
          "*": "deny",
          "inspector": "allow",
          "fixer": "allow",
          "reporter": "allow"
        }
      }
    },

    "coder": {
      "mode": "subagent",
      "description": "Implements tasks assigned by Builder, following the PRD exactly. Tracks own progress via todowrite.",
      "prompt": "{file:./prompts/coder.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "todowrite": "allow",
        "bash": "allow",
        "task": "deny"
      }
    },

    "tester": {
      "mode": "subagent",
      "description": "Runs tests on implemented code and reports results (PASS/FAIL/BLOCKED) with coverage gaps. Cannot fix code, redesign tests, or decide next steps.",
      "prompt": "{file:./prompts/tester.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "todowrite": "deny",
        "bash": "allow",
        "task": "deny"
      }
    },

    "reviewer": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Boolean gate for Builder: compares implementation against PRD definition-of-done. PASS/FAIL + gap list only.",
      "prompt": "{file:./prompts/reviewer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny"
      }
    },

    "writer": {
      "mode": "subagent",
      "description": "Text-file executor for Builder. Writes and edits .md/.txt files across the project — like coder but for documents only. No bash.",
      "prompt": "{file:./prompts/writer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": "deny",
        "todowrite": "deny",
        "task": "deny"
      }
    },

    "researcher": {
      "mode": "subagent",
      "description": "Researches technical and codebase context for Planner during PRD preparation. Outputs confirmed_facts / inferred_facts / unknowns / risks only.",
      "prompt": "{file:./prompts/researcher.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "deny"
      }
    },

    "plan-writer": {
      "mode": "subagent",
      "description": "Stateless formatter for Planner. Produces PRD documents from structured input — no inference, no decisions. PRD mode only.",
      "prompt": "{file:./prompts/plan-writer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "*": "deny",
          "docs/plans/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/plans/**": "allow"
        },
        "bash": "deny",
        "task": "deny"
      }
    },

    "plan-checker": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Boolean gate for Planner: checks PRD completeness against original user request. PASS/FAIL + gap list only.",
      "prompt": "{file:./prompts/plan-checker.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny"
      }
    },

    "inspector": {
      "mode": "subagent",
      "description": "Root-cause analysis for Debugger. Investigates bugs via codebase and web research. Outputs confirmed_facts / inferred_facts / unknowns / risks only.",
      "prompt": "{file:./prompts/inspector.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "find *": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "task": "deny"
      }
    },

    "fixer": {
      "mode": "subagent",
      "description": "Implements bug fixes for Debugger. Follows root cause from inspector. Like coder but focused on fixes — minimal change, root-cause targeting.",
      "prompt": "{file:./prompts/fixer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "todowrite": "allow",
        "bash": "allow",
        "task": "deny"
      }
    },

    "reporter": {
      "mode": "subagent",
      "description": "Stateless formatter for Debugger. Produces diagnosis + remedy reports from structured input — no inference, no decisions. Summary mode only.",
      "prompt": "{file:./prompts/reporter.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "bash": "deny",
        "task": "deny"
      }
    }
  }
}
